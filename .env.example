# Backend (FastAPI) environment variables
# Copy ke .env (gitignored) untuk dev, atau set di Render dashboard untuk prod

# Required: Groq API key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Optional: CORS regex untuk domain frontend production
# Default sudah accept localhost any port. Untuk production tambah Vercel domain.
# Example: CORS_ORIGIN_REGEX=https://helix-.*\.vercel\.app|https://helix\.akselera\.tech
CORS_ORIGIN_REGEX=
